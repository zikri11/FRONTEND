# ── Template env Frontend EgNET ───────────────────────────────────────────
# Salin file ini jadi `.env` lalu isi nilainya:  cp .env.example .env
# Proyek ini memakai SATU file env (`.env`). Jangan bikin .env.local dsb.
# Vite hanya membaca variabel ber-awalan VITE_.

# ── Backend ───────────────────────────────────────────────────────────────
# SATU-SATUNYA tempat menaruh domain backend. Ganti domain? cukup ubah baris
# ini di `.env` — vite.config.ts membacanya via loadEnv (tak ada URL hardcode
# di kode; fallback-nya cuma http://localhost:4000). Isi TANPA prefix /api.
# Dipakai proxy dev server untuk REST (/api) dan WebSocket (/socket.io).
VITE_BACKEND_ORIGIN=https://host-backend-anda.example

# Base URL yang dipakai axios (src/lib/axios.ts):
#   DEV  → "/api"  = lewat proxy dev server, bebas CORS  ← default
#   PROD → URL penuh termasuk /api, contoh:
#          https://host-backend-anda.example/api
# Origin WebSocket diturunkan otomatis dari nilai ini (src/lib/socket-url.ts
# membuang akhiran /api), jadi tidak perlu variabel terpisah.
VITE_API_BASE_URL=/api

# ── Google OAuth ──────────────────────────────────────────────────────────
# Client ID tipe "Web application" (sama dengan yang dipakai backend).
# Kosong = tombol "Lanjut dengan Google" otomatis disembunyikan.
# Daftarkan origin frontend di Authorized JavaScript origins Google Console.
VITE_GOOGLE_CLIENT_ID=

# ── Clerk (opsional) ──────────────────────────────────────────────────────
# Hanya untuk route demo /clerk. Kosong = app tetap jalan (guarded).
VITE_CLERK_PUBLISHABLE_KEY=
