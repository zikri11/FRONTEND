VITE_CLERK_PUBLISHABLE_KEY=

# Base URL API backend (default proxy ke http://localhost:4000/api).
VITE_API_BASE_URL=/api

# Google OAuth Client ID (tipe "Web application"). Client ID sama dipakai
# frontend & backend. Kosong = tombol "Lanjut dengan Google" disembunyikan.
# Pastikan http://localhost:5173 terdaftar di Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=